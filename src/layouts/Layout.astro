---
import "../styles/global.css";
import Navbar from "../components/Navbar.astro";
import { ClientRouter } from 'astro:transitions';

interface Props {
	title: string;
	description?: string;
}

const { title, description = "Ananthapadmanabhan M - Senior MERN Stack Developer Portfolio" } = Astro.props;
---

<!DOCTYPE html>
<html lang="en" class="light">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content={description} />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		
		<!-- Google Fonts -->
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&family=Gochi+Hand&display=swap" rel="stylesheet">
		
		<ClientRouter />
		
		<title>{title} | Ananthapadmanabhan M</title>

		<!-- SEO -->
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:type" content="website" />
		<meta name="twitter:card" content="summary_large_image" />
	</head>
	<body class="min-h-screen selection:bg-[#4A90E2] selection:text-white overflow-x-hidden w-full bg-[#F4F4F4]">
		<Navbar />
		<main class="max-w-6xl mx-auto px-6 pt-8 md:pt-32 pb-32 md:pb-20 overflow-x-hidden">
			<slot />
		</main>
		
		<footer class="max-w-6xl mx-auto px-6 py-20 border-t border-[#E0E0E0] text-[#2E2E2E]/40 text-sm flex flex-col md:flex-row justify-between items-center gap-8">
			<div class="flex items-center gap-6">
				<div class="text-2xl font-black tracking-tighter text-[#2E2E2E]">AM<span class="text-[#4A90E2]">.</span></div>
				<div class="h-6 w-[1px] bg-[#E0E0E0] hidden md:block"></div>
				<p class="font-medium">© 2026 Ananthapadmanabhan M. <span class="hidden md:inline">Built with passion & precision.</span></p>
			</div>
			<div class="flex gap-10 font-bold uppercase tracking-widest text-[10px]">
				<a href="https://github.com/blitzbugg" class="text-[#2E2E2E]/60 hover:text-[#4A90E2] transition-colors">GitHub</a>
				<a href="https://www.linkedin.com/in/ananthapadmanabhan-m/" class="text-[#2E2E2E]/60 hover:text-[#4A90E2] transition-colors">LinkedIn</a>
				<a href="https://medium.com/@blitzbugg" class="text-[#2E2E2E]/60 hover:text-[#4A90E2] transition-colors">Medium</a>
			</div>
		</footer>
	</body>
</html>

<style is:global>
	:root {
		scroll-behavior: smooth;
	}
	
	/* Smooth Page Transitions */
	::view-transition-old(root),
	::view-transition-new(root) {
		animation-duration: 0.5s;
	}
</style>
