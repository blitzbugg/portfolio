---
import "../styles/global.css";
import Navbar from "../components/Navbar.astro";
import { ClientRouter } from 'astro:transitions';

interface Props {
	title: string;
	description?: string;
}

const { title, description = "Ananthapadmanabhan M - Portfolio" } = Astro.props;
---

<!DOCTYPE html>
<html lang="en" class="light">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content={description} />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.png" />
		<meta name="generator" content={Astro.generator} />
		
		<!-- Google Fonts -->
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&family=Gochi+Hand&family=Caveat:wght@400;700&family=Italianno&display=swap" rel="stylesheet">
		
		<ClientRouter />
		
		<title>{title} | Ananthapadmanabhan M</title>

		<!-- Advanced SEO -->
		<meta name="robots" content="index, follow" />
		<meta name="author" content="Ananthapadmanabhan M" />
		<link rel="canonical" href="https://blitzbugg.vercel.app/" />
		<link rel="sitemap" href="/sitemap-index.xml" />
		<meta name="theme-color" content="#F4F4F4" />

		<!-- Open Graph / Facebook / WhatsApp -->
		<meta property="og:type" content="website" />
		<meta property="og:url" content="https://blitzbugg.vercel.app/" />
		<meta property="og:title" content={`${title} | Ananthapadmanabhan M`} />
		<meta property="og:description" content={description} />
		<meta property="og:image" content="https://blitzbugg.vercel.app/og-preview.png" />
		<meta property="og:image:width" content="1200" />
		<meta property="og:image:height" content="630" />

		<!-- Twitter / X -->
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:url" content="https://blitzbugg.vercel.app/" />
		<meta name="twitter:title" content={`${title} | Ananthapadmanabhan M`} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content="https://blitzbugg.vercel.app/og-preview.png" />
		<meta name="twitter:site" content="@blitzbugg" />

		<!-- JSON-LD Structured Data (Schema.org) -->
		<script type="application/ld+json" is:inline>
			{
				"@context": "https://schema.org",
				"@type": "Person",
				"name": "Ananthapadmanabhan M",
				"url": "https://blitzbugg.vercel.app/",
				"jobTitle": "Full Stack Developer",
				"sameAs": [
					"https://www.linkedin.com/in/ananthapadmanabhan-m/",
					"https://github.com/blitzbugg",
					"https://medium.com/@blitzbugg",
					"https://blitzbugg.vercel.app/",
					"https://x.com/blitzbugg",
					"https://www.instagram.com/blitzbugg/",
					"https://dev.to/blitzbugg",
					"https://www.threads.net/@blitzbugg",
					"https://leetcode.com/u/blitzbugg",
					"https://www.hackerrank.com/profile/blitzbugg",
					"https://discord.com/users/blitzbugg",

				],
				"description": "Full Stack Developer passionate about building scalable, production-ready web applications with experience in React, Node.js, and TypeScript."
			}
		</script>
	</head>
	<body class="min-h-screen selection:bg-primary selection:text-white overflow-x-hidden w-full bg-background">
		<Navbar />
		<main class="max-w-6xl mx-auto px-6 pt-8 md:pt-32 pb-32 md:pb-20 overflow-x-hidden">
			<slot />
		</main>
		
		<footer class="max-w-6xl mx-auto px-6 py-20 border-t border-border text-foreground/40 text-sm flex flex-col md:flex-row justify-between items-center gap-8">
			<div class="flex items-center gap-6">
				<div class="text-2xl font-black tracking-tighter text-foreground">AM<span class="text-primary">.</span></div>
				<div class="h-6 w-[1px] bg-border hidden md:block"></div>
				<p class="font-medium">© 2026 Ananthapadmanabhan M. <span class="hidden md:inline">Built with passion & precision.</span></p>
			</div>
			<div class="flex gap-10 font-bold uppercase tracking-widest text-[10px]">
				<a href="https://github.com/blitzbugg" class="text-foreground/60 hover:text-primary transition-colors">GitHub</a>
				<a href="https://www.linkedin.com/in/ananthapadmanabhan-m/" class="text-foreground/60 hover:text-primary transition-colors">LinkedIn</a>
				<a href="https://medium.com/@blitzbugg" class="text-foreground/60 hover:text-primary transition-colors">Medium</a>
			</div>
		</footer>

		<script is:inline>
			const initReveal = () => {
				const observerOptions = {
					root: null,
					threshold: 0.1,
					rootMargin: '0px'
				};

				const observer = new IntersectionObserver((entries) => {
					entries.forEach((entry) => {
						if (entry.isIntersecting) {
							entry.target.classList.add('active');
							// Optional: stop observing once revealed
							// observer.unobserve(entry.target);
						}
					});
				}, observerOptions);

				const revealElements = document.querySelectorAll('[class*="reveal"]');
				revealElements.forEach((el) => observer.observe(el));
			};

			// Run on initial load
			initReveal();

			// Run on every view transition (navigation)
			document.addEventListener('astro:after-swap', initReveal);
		</script>
	</body>
</html>

<style is:global>
	:root {
		scroll-behavior: smooth;
	}
	
	/* Smooth Page Transitions */
	::view-transition-old(root),
	::view-transition-new(root) {
		animation-duration: 0.5s;
	}
</style>
