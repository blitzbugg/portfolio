---
import Layout from "../../layouts/Layout.astro";
import SectionHeader from "../../components/SectionHeader.astro";
import TimelineItem from "../../components/TimelineItem.astro";
import { experience } from "../../data/info";
---

<Layout title="Experience">
  <SectionHeader title="Professional Experience" subtitle="Journey" />
  
  <div class="mt-20 max-w-4xl">
    {experience.map((exp) => (
      <TimelineItem 
        title={exp.role}
        subtitle={exp.company}
        period={exp.period}
        description={exp.description}
      />
    ))}
  </div>

 <div class="mt-20 p-12 rounded-[3rem] bg-white border border-[#E0E0E0] shadow-sm shadow-[#2E2E2E]/5">
  <h3 class="text-2xl font-black mb-6 text-[#2E2E2E]">Core Focus</h3>
  <p class="text-[#2E2E2E]/70 leading-relaxed text-lg font-light">
    As a freelance developer, I focus on building high-performance, production-ready web applications. I handle the full lifecycle — from crafting responsive frontends to designing secure backend APIs and deploying scalable systems on VPS environments.
  </p>
</div>
</Layout>
