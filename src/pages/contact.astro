---
import { Icon } from "astro-icon/components";
import Layout from "../layouts/Layout.astro";
import SectionHeader from "../components/SectionHeader.astro";
import Blob from "../components/Blob.astro";
import { personalInfo } from "../data/info";

const { socials } = personalInfo;
const email = "ananthapadmanabhanm98@gmail.com";
---

<Layout title="Contact | Ananthapadmanabhan">
	<section class="py-12 md:py-20 relative overflow-hidden px-4">
		<Blob className="top-0 -left-20 opacity-30" size="w-72 h-72 sm:w-96 sm:h-96" color="bg-primary/10" />
		<Blob className="bottom-20 -right-20 opacity-20" size="w-64 h-64 sm:w-80 sm:h-80" color="bg-secondary/10" />

		<SectionHeader title="Let's build something together" subtitle="Contact" />

		<div class="grid grid-cols-1 lg:grid-cols-2 gap-12 mt-12 relative z-10">
			<!-- Contact Info -->
			<div class="space-y-8 animate-slide-up">
				<p class="text-xl md:text-3xl text-foreground/70 leading-relaxed font-light">
					Whether you have a question, a project idea, or just want to say hi, my inbox is always open.
				</p>

				<div class="space-y-6 pt-8">
					<a 
						href={`mailto:${email}`}
						class="group flex items-center justify-between p-8 rounded-[2rem] bg-white border border-border hover:border-primary/30 transition-all duration-500 shadow-sm hover:shadow-xl shadow-foreground/5"
					>
						<div class="flex items-center gap-6">
							<div class="w-14 h-14 rounded-2xl bg-primary/5 flex items-center justify-center text-primary group-hover:scale-110 transition-transform p-3">
								<Icon name="lucide:mail" class="w-full h-full" />
							</div>
							<div class="flex flex-col">
								<span class="text-[10px] uppercase font-bold tracking-[0.2em] text-foreground/40 mb-1">Email Me</span>
								<span class="text-lg md:text-xl font-bold text-foreground break-all">{email}</span>
							</div>
						</div>
						<div class="w-10 h-10 rounded-full bg-background flex items-center justify-center group-hover:bg-primary group-hover:text-white transition-all">
							<Icon name="lucide:arrow-up-right" class="w-5 h-5" />
						</div>
					</a>

					<div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
						<!-- Resume Card -->
						<a 
							href="/My_resume.pdf"
							download
							class="group p-8 rounded-[2rem] bg-white border border-border hover:border-primary/30 transition-all duration-500 shadow-sm hover:shadow-xl shadow-foreground/5"
						>
							<div class="flex items-center justify-between mb-6">
								<div class="w-12 h-12 rounded-2xl bg-primary/5 flex items-center justify-center text-primary group-hover:scale-110 transition-transform p-2.5">
									<Icon name="lucide:file-user" class="w-full h-full" />
								</div>
								<div class="text-foreground/20 group-hover:text-primary group-hover:translate-x-1 group-hover:-translate-y-1 transition-all">
									<Icon name="lucide:arrow-up-right" class="w-5 h-5" />
								</div>
							</div>
							<h4 class="text-xl font-bold text-foreground capitalize">My Resume</h4>
						</a>

						{Object.entries(socials).map(([platform, url]) => (
							<a 
								href={url}
								target="_blank"
								class="group p-8 rounded-[2rem] bg-white border border-border hover:border-secondary/30 transition-all duration-500 shadow-sm hover:shadow-xl shadow-foreground/5"
							>
								<div class="flex items-center justify-between mb-6">
									<div class="w-12 h-12 rounded-2xl bg-secondary/5 flex items-center justify-center text-secondary group-hover:scale-110 transition-transform p-2.5">
										{platform === 'github' && <Icon name="simple-icons:github" class="w-full h-full" />}
										{platform === 'linkedin' && <Icon name="simple-icons:linkedin" class="w-full h-full" />}
										{platform === 'medium' && <Icon name="simple-icons:medium" class="w-full h-full" />}
									</div>
									<div class="text-foreground/20 group-hover:text-secondary group-hover:translate-x-1 group-hover:-translate-y-1 transition-all">
										<Icon name="lucide:arrow-up-right" class="w-5 h-5" />
									</div>
								</div>
								<h4 class="text-xl font-bold text-foreground capitalize">{platform}</h4>
							</a>
						))}
					</div>
				</div>
			</div>

			<!-- Creative Element -->
			<div class="lg:pl-12 flex items-center justify-center animate-slide-up" style="animation-delay: 0.2s;">
				<div class="relative w-full aspect-square max-w-md">
					<div class="absolute inset-0 bg-gradient-to-tr from-primary/20 via-secondary/10 to-transparent rounded-[3rem] animate-morph"></div>
					<div class="absolute inset-8 bg-white/40 backdrop-blur-3xl rounded-[2.5rem] border border-white/50 shadow-2xl flex items-center justify-center p-12 text-center overflow-hidden group">
						<div class="relative z-10">
							<div class="font-caveat text-4xl text-primary mb-6 rotate-[-2deg] group-hover:rotate-0 transition-transform">
								Quick Note
							</div>
							<p class="text-xl font-light text-foreground/80 leading-relaxed italic">
								"I'm generally quick to respond. Let's create something meaningful together!"
							</p>
						</div>
						<!-- Decorative circles -->
						<div class="absolute -top-10 -right-10 w-32 h-32 bg-primary/10 rounded-full blur-2xl"></div>
						<div class="absolute -bottom-10 -left-10 w-32 h-32 bg-secondary/10 rounded-full blur-2xl"></div>
					</div>
				</div>
			</div>
		</div>

		<div class="mt-32 text-center max-w-2xl mx-auto opacity-50">
			<div class="w-px h-24 bg-gradient-to-b from-primary to-transparent mx-auto mb-10"></div>
			<p class="text-sm font-bold uppercase tracking-[0.5em] text-primary">Based in Kerala, India (IST)</p>
		</div>
	</section>
</Layout>
