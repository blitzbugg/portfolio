---
interface Props {
  title: string;
  subtitle: string;
  period: string;
  description: string;
  className?: string;
}

const { title, subtitle, period, description, className = "" } = Astro.props;
---

<div class={`relative pl-10 pb-16 border-l border-[#E0E0E0] last:border-0 ${className}`}>
  <div class="absolute left-[-6px] top-0 w-[12px] h-[12px] rounded-full bg-[#4A90E2] shadow-[0_0_20px_rgba(74,144,226,0.3)] border-2 border-background"></div>
  
  <div class="flex flex-col md:flex-row md:justify-between md:items-start mb-6 gap-4">
    <div class="space-y-1">
      <h3 class="text-3xl font-black tracking-tighter text-[#2E2E2E]">{title}</h3>
      <p class="text-[#4A90E2] font-bold uppercase tracking-widest text-xs">{subtitle}</p>
    </div>
    <span class="text-[10px] font-black tracking-[0.2em] text-[#2E2E2E]/60 bg-[#F4F4F4] px-4 py-2 rounded-xl border border-[#E0E0E0] uppercase shrink-0">{period}</span>
  </div>
  
  <p class="text-lg text-[#2E2E2E]/70 leading-relaxed max-w-3xl font-light">
    {description}
  </p>
</div>
