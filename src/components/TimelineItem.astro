---
interface Props {
  title: string;
  subtitle: string;
  period: string;
  description: string;
  className?: string;
}

const { title, subtitle, period, description, className = "" } = Astro.props;
---

<div class={`relative pl-10 pb-16 border-l border-border last:border-0 reveal-left ${className}`}>
  <div class="absolute left-[-6px] top-0 w-[12px] h-[12px] rounded-full bg-primary shadow-[0_0_20px_rgba(45,116,199,0.3)] border-2 border-background"></div>
  
  <div class="flex flex-col md:flex-row md:justify-between md:items-start mb-6 gap-4">
    <div class="space-y-1">
      <h3 class="text-3xl font-black tracking-tighter text-foreground">{title}</h3>
      <p class="text-primary font-bold uppercase tracking-widest text-xs">{subtitle}</p>
    </div>
    <span class="text-[10px] font-black tracking-[0.2em] text-foreground/60 bg-background px-4 py-2 rounded-xl border border-border uppercase shrink-0">{period}</span>
  </div>
  
  <p class="text-lg text-[#2E2E2E]/70 leading-relaxed max-w-3xl font-light">
    {description}
  </p>
</div>
