---

<div class="flex items-center gap-6 px-8 py-6 rounded-3xl bg-white border border-border hover:border-primary/40 transition-all duration-500 hover:bg-background/50 cursor-default group shadow-sm hover:shadow-xl shadow-foreground/5">
  <div class="w-12 h-12 flex items-center justify-center text-primary group-hover:scale-110 transition-transform bg-background rounded-2xl p-2.5">
    <Fragment set:html={skillIcon} />
  </div>
  <div class="flex flex-col">
    <span class="text-xl font-black text-foreground group-hover:text-primary transition-colors tracking-tight leading-none mb-1">{name}</span>
    <span class="text-[10px] uppercase tracking-widest text-foreground/30 font-bold">Proficient</span>
  </div>
</div>
