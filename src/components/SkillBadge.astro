---
import { Icon } from "astro-icon/components";

interface Props {
  name: string;
}

const { name } = Astro.props;

// Map skill names to Iconify icon names
const iconMap: Record<string, string> = {
  "HTML5": "simple-icons:html5",
  "CSS3": "simple-icons:css3",
  "JavaScript (ES6+)": "simple-icons:javascript",
  "React": "simple-icons:react",
  "Next.js": "simple-icons:nextdotjs",
  "Tailwind CSS": "simple-icons:tailwindcss",
  "Node.js": "simple-icons:nodedotjs",
  "Express.js": "simple-icons:express",
  "TypeScript": "simple-icons:typescript",
  "MongoDB": "simple-icons:mongodb",
  "PostgreSQL": "simple-icons:postgresql",
  "MySQL": "simple-icons:mysql",
  "Git": "simple-icons:git",
  "GitHub": "simple-icons:github",
  "Postman": "simple-icons:postman",
  "Prisma ORM": "simple-icons:prisma",
  "Socket.IO": "simple-icons:socketdotio",
  "Canvas API": "simple-icons:canvas",
  "NGINX": "simple-icons:nginx",
  "Alma Linux": "simple-icons:almalinux",
  "Bootstrap": "simple-icons:bootstrap",
  "Payload CMS": "simple-icons:payloadcms",
  "Astro": "simple-icons:astro",
  "Vite": "simple-icons:vite",
  "PHP": "simple-icons:php",
  "Go": "simple-icons:go",
};

const iconName = iconMap[name] || "lucide:code";
---

<div class="flex items-center gap-6 px-8 py-6 rounded-3xl bg-white border border-border hover:border-primary/40 transition-all duration-500 hover:bg-background/50 cursor-default group shadow-sm hover:shadow-xl shadow-foreground/5 reveal-scale">
  <div class="w-12 h-12 flex items-center justify-center group-hover:text-primary group-hover:scale-110 transition-transform bg-background rounded-2xl p-2.5">
    <Icon name={iconName} class="w-full h-full" />
  </div>
  <div class="flex flex-col">
    <span class="text-xl font-black text-foreground group-hover:text-primary transition-colors tracking-tight leading-none mb-1">{name}</span>
  </div>
</div>
