---
import Tegaki from "tegaki/astro";
import caveat from "tegaki/fonts/caveat";

interface Props {
  title: string;
  description: string;
  tech: string[];
  link: string;
  github?: string;
}

const { title, description, tech, link, github } = Astro.props;
---

<div class="group block p-6 md:p-10 rounded-[2rem] md:rounded-[3rem] border border-[#E0E0E0] bg-white hover:border-[#4A90E2]/20 transition-all duration-700 relative overflow-hidden shadow-sm hover:shadow-xl shadow-[#2E2E2E]/5">
  <!-- Background Glow -->
  <div class="absolute -right-20 -top-20 w-80 h-80 bg-[#4A90E2]/5 rounded-full blur-[100px] group-hover:bg-[#4A90E2]/10 transition-colors"></div>

  <div class="relative z-10">
    <div class="flex justify-between items-start mb-6 md:mb-10">
      <div class="space-y-3">
        <a href={link} class="block">
          <h3 class="text-2xl sm:text-3xl md:text-5xl font-black tracking-tighter text-[#2E2E2E] group-hover:text-[#4A90E2] transition-all duration-500 leading-[1.1]">{title}</h3>
        </a>
        <div class="opacity-0 group-hover:opacity-100 transition-opacity transform translate-y-2 group-hover:translate-y-0 duration-500 text-[#4A90E2]">
           <Tegaki text="View Case Study -->" font={caveat} size={22} duration={1} client:load />
        </div>
      </div>
      
      <div class="flex gap-3">
        {github && (
          <a href={github} target="_blank" class="w-14 h-14 rounded-2xl bg-[#F4F4F4] border border-[#E0E0E0] flex items-center justify-center hover:bg-[#2E2E2E] hover:text-white transition-all duration-500 hover:-rotate-12 shadow-md" title="View Source">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"/></svg>
          </a>
        )}
        <a href={link} class="w-14 h-14 rounded-2xl bg-[#F4F4F4] border border-[#E0E0E0] flex items-center justify-center group-hover:bg-[#4A90E2] group-hover:text-white transition-all duration-500 group-hover:rotate-12 shadow-md" title="Live Demo">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M7 7h10v10"/><path d="M7 17 17 7"/></svg>
        </a>
      </div>
    </div>
    
    <p class="text-xl text-[#2E2E2E]/70 mb-10 leading-relaxed max-w-lg font-light">
      {description}
    </p>
    
    <div class="flex flex-wrap gap-4">
      {tech.map((t) => (
        <span class="px-5 py-2 rounded-xl bg-[#F4F4F4] border border-[#E0E0E0] text-[10px] font-black uppercase tracking-[0.2em] text-[#2E2E2E]/60 group-hover:border-[#4A90E2]/30 group-hover:text-[#4A90E2] transition-colors shadow-sm">
          {t}
        </span>
      ))}
    </div>
  </div>
</div>

<style>
  a {
    animation: fade-in 1s ease-out forwards;
  }
</style>
