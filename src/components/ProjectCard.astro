---
import { Icon } from "astro-icon/components";

interface Props {
  title: string;
  description: string;
  tech: string[];
  link: string;
  github?: string;
}

const { title, description, tech, link, github } = Astro.props;
---

<div class="group block p-6 md:p-10 rounded-[2rem] md:rounded-[3rem] border border-[#E0E0E0] bg-white hover:border-primary/20 transition-all duration-700 relative overflow-hidden shadow-sm hover:shadow-xl shadow-[#2E2E2E]/5 reveal">
  <!-- Background Glow -->
  <div class="absolute -right-20 -top-20 w-80 h-80 bg-primary/5 rounded-full blur-[100px] group-hover:bg-primary/10 transition-colors"></div>

  <div class="relative z-10">
    <div class="flex justify-between items-start mb-6 md:mb-10">
      <div class="space-y-3">
        <a href={link} class="block">
          <h3 class="text-2xl sm:text-3xl md:text-5xl font-black tracking-tighter text-[#2E2E2E] group-hover:text-primary transition-all duration-500 leading-[1.1]">{title}</h3>
        </a>
        <div class="opacity-0 group-hover:opacity-100 transition-opacity transform translate-y-2 group-hover:translate-y-0 duration-500 text-primary font-caveat text-3xl pb-2">
            View Live -->
        </div>
      </div>
      
      <div class="flex gap-3">
        {github && (
          <a href={github} target="_blank" class="w-14 h-14 rounded-2xl bg-[#F4F4F4] border border-[#E0E0E0] flex items-center justify-center hover:bg-[#2E2E2E] hover:text-white transition-all duration-500 hover:-rotate-12 shadow-md" title="View Source">
            <Icon name="simple-icons:github" class="w-6 h-6" />
          </a>
        )}
        <a href={link} class="w-14 h-14 rounded-2xl bg-[#F4F4F4] border border-[#E0E0E0] flex items-center justify-center group-hover:bg-primary group-hover:text-white transition-all duration-500 group-hover:rotate-12 shadow-md" title="Live Demo">
          <Icon name="lucide:arrow-up-right" class="w-6 h-6" />
        </a>
      </div>
    </div>
    
    <p class="text-xl text-[#2E2E2E]/70 mb-10 leading-relaxed max-w-lg font-light">
      {description}
    </p>
    
    <div class="flex flex-wrap gap-4">
      {tech.map((t) => (
        <span class="px-5 py-2 rounded-xl bg-[#F4F4F4] border border-[#E0E0E0] text-[10px] font-black uppercase tracking-[0.2em] text-[#2E2E2E]/60 group-hover:border-primary/30 group-hover:text-primary transition-colors shadow-sm">
          {t}
        </span>
      ))}
    </div>
  </div>
</div>

<style>
  a {
    animation: fade-in 1s ease-out forwards;
  }
</style>
